Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On

  # The application is intended to expose only route controllers and assets.
  RewriteRule (^|/)\. - [F]
  RewriteRule ^(config|database|lib)(/|$) - [F]
  RewriteRule ^(AGENTS\.md|CONTRIBUTING\.md|README\.md|SECURITY\.md|LICENSE|setup\.sh)$ - [F]
</IfModule>

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "same-origin"
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; object-src 'none'; base-uri 'self'; frame-ancestors 'self'; form-action 'self'"
</IfModule>
